{
    "vitest.packageManager": "pnpm",
    "vitest.configSearchPatternExclude": "**/node_modules/**",
    "files.exclude": {
        "dist": true
    },
    "search.exclude": {
        "dist": true
    },
    "files.watcherExclude": {
        "dist/**": true
    },
    "chat.tools.compressOutput.enabled": true,
    "chat.tools.terminal.autoApprove": {
        "pnpm": true,
        "npx vitest": true,
        "npx tsc": true,
        "git fetch": true,
        "git commit": true,
        "git worktree": true,
        "git checkout": true,
        "git merge": true,
        "git -C /home/zymurge/Dev/onion": true,
        "docker compose": true,
        "docker exec": true,
        "set": true,
        "printf": true,
        "tee": true,
        "awk": true
    },
    "chat.utilityModel": "copilot/gpt-5.4-mini",
    "chat.utilitySmallModel": "copilot/gpt-5-mini",
    "github.copilot.chat.cli.forkSessions.enabled": true,
    "github.copilot.chat.responsesApi.toolSearchTool.enabled": true,
    "github.copilot.chat.localIndex.enabled": true,
    "npm.scriptRunner": "pnpm"
}