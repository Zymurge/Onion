{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run server (pnpm dev)",
			"type": "node",
			"request": "launch",
			"cwd": "${workspaceFolder}",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["dev"],
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"env": {
				"LOG_LEVEL": "warn"
			}
		}
	]
}