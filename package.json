{
  "name": "onion",
  "version": "0.1.0",
  "description": "Shrek-themed reimplementation of OGRE",
  "license": "GPL-3.0-only",
  "type": "module",
  "imports": {
    "#server/*": "./server/*.ts",
    "#shared/*": "./shared/*.ts",
    "#web/*": ["./web/*.ts", "./web/*.tsx"]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "cli": "tsx server/cli/index.ts",
    "cli:dev": "tsx watch server/cli/index.ts",
    "cli:test-game": "npm run build && node dist/server/cli/test-game.js",
    "web:dev": "pnpm --dir web dev",
    "web:build": "pnpm --dir web build",
    "web:preview": "pnpm --dir web preview",
    "web:lint": "pnpm --dir web lint",
    "build": "tsc && node scripts/write-dist-package-json.mjs",
    "start:cli": "node dist/server/cli/index.js",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:web:coverage": "vitest run --project web --coverage --coverage.include=web/**",
    "docs:serve": "npx http-server docs/api -p 3001 -c-1 --cors"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.5",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-json-print": "^0.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
